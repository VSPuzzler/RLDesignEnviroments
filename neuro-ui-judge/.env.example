# NeuroUI Judge — environment variable template.
#
# Copy this file to `.env` (same folder) and fill in the values.
# Both files are gitignored at the repo root.
#
# Loading order (highest wins):
#   1. variables already exported in your shell
#   2. .env in this folder (auto-loaded by services/scorer/api.py on import)
#   3. hardcoded fallbacks below

# ── Storage ─────────────────────────────────────────────────────────────────
# Where the SQLite database lives. Relative paths are resolved against
# neuro-ui-judge/. Default keeps everything inside data/.
DATABASE_URL="file:./data/neuroui.db"

# ── OpenRouter (LLM + vision) ───────────────────────────────────────────────
# Required for: agent's llm_redesign, the image describer that feeds TRIBE,
# and any future judge calls. Get one at https://openrouter.ai/keys.
OPENROUTER_API_KEY=""

# Default OpenRouter model used by every text/vision call. Pick a model with
# vision support so the image-describer pre-processor works.
# Examples that work today (2026-04):
#   openai/gpt-4.1-mini        (default — fast vision, cheap)
#   anthropic/claude-sonnet-4.5
#   google/gemini-2.0-flash
OPENROUTER_MODEL="openai/gpt-4.1-mini"

# Headers OpenRouter wants for attribution / rate-limit fairness.
OPENROUTER_APP_NAME="NeuroUI Judge"
NEXT_PUBLIC_APP_URL="http://localhost:8000"

# ── TRIBE v2 sidecar ────────────────────────────────────────────────────────
# URL of the optional FastAPI sidecar that runs Meta's facebook/tribev2 in a
# separate Python 3.11 environment. Leave as-is to use the default; set
# TRIBE_V2_SERVICE_URL="" to force mock mode even if the sidecar is up.
TRIBE_V2_SERVICE_URL="http://localhost:7860"

# When set to "1", the main app blocks on the sidecar at startup and refuses
# to start if it is unreachable. Default ("0") falls back to mock cleanly.
TRIBE_V2_REQUIRED="0"

# Required by TRIBE v2 internally (gated meta-llama/Llama-3.2-3B). Only used
# when the sidecar boots; the main app never reads this directly.
HUGGING_FACE_HUB_TOKEN=""
