# ui_brain_preference — environment variable template.
#
# Copy this file to `.env` (same folder) and fill in the values.
# `config.py` auto-loads `.env` via python-dotenv on import, so you
# don't need to `source` anything — just create the file.
#
# `.env` is gitignored at the repo root.

# ── Required ────────────────────────────────────────────────────────────────
# Get one at https://openrouter.ai/keys (starts with "sk-or-v1-").
OPENROUTER_API_KEY=

# ── Optional model overrides ────────────────────────────────────────────────
# Any model slug listed at https://openrouter.ai/models works. The original
# code defaulted to "anthropic/claude-3.5-sonnet" which is now stale; the
# fresher Sonnet 4.5 is a good drop-in replacement.

# Used to generate the two HTML/CSS variants (needs strong front-end ability).
GENERATION_MODEL=anthropic/claude-sonnet-4.5

# Used by the LLM judge that compares ROI activations.
JUDGE_MODEL=anthropic/claude-sonnet-4.5

# ── Optional: real Tribe V2 ─────────────────────────────────────────────────
# If `tribev2` is not importable in this venv (the default — it's not on PyPI),
# `brain_scorer.py` falls back to a deterministic simulation. To wire in real
# Tribe V2, install Meta's package separately and set:
#   HUGGING_FACE_HUB_TOKEN=hf_...
# Real Tribe V2 also requires access to gated meta-llama/Llama-3.2-3B.
HUGGING_FACE_HUB_TOKEN=
